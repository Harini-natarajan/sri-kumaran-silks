# ===========================================
# SriKumaranSilks - Server Environment Variables
# ===========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb://127.0.0.1:27017/srikumaransilks

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ===========================================
# STRIPE PAYMENT GATEWAY CONFIGURATION
# ===========================================
# Get your API keys from: https://dashboard.stripe.com/apikeys
#
# For testing, use test keys (start with pk_test_ and sk_test_)
# For production, use live keys (start with pk_live_ and sk_live_)
#
# IMPORTANT SECURITY NOTES:
# 1. Never commit your actual API keys to version control
# 2. Use environment-specific keys (test for development, live for production)
# 3. Rotate keys if they are ever exposed
# ===========================================

# Stripe Publishable Key (Can be exposed to client - used in checkout)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Secret Key (Server-side only - NEVER expose this)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook Secret
# Get this from: https://dashboard.stripe.com/webhooks
# Used to verify webhook signatures for payment events
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===========================================
# CLIENT CONFIGURATION
# ===========================================

# Frontend URL (for CORS and redirects)
CLIENT_URL=http://localhost:5173

# ===========================================
# OPTIONAL: Additional Configuration
# ===========================================

# Email service configuration (if implementing order confirmation emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Cloudinary configuration (if implementing image uploads)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
